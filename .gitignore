# NuGet
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if necessary however generally you should not ignore the props/targets
#!**/[Pp]ackages/*.props
#!**/[Pp]ackages/*.targets

# Publish output
**/[Pp]ublish/
*.pubxml
*.publishproj

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

