# =========================
# Build artifacts
# =========================
bin/
obj/
out/
publish/

# Python build caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs & temp files
*.log
*.tmp
*.swp

# OS cruft
.DS_Store
Thumbs.db
ehthumbs.db

# Git
.git
.gitignore
.gitattributes

# IDE settings
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Package caches
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
pip-wheel-metadata/
pip-log.txt

# Docker-specific
docker-compose.override.yml
docker-compose.override.*.yml

# Tests (not needed in Docker image)
tests/

# Documentation & assets (not needed in build context)
*.md
docs/
img/

# Auxiliary repository directories that bloat context but are never copied
# into the image. Each entry mirrors a real top-level directory; remove if
# the directory is removed from the repo.
archive/
audits/
benchmarks/
demos/
launch/
announce/
talks/
perf/
dist/
coverage/

# Repo-root tooling that does not belong in the build context
Makefile
Dockerfile
Dockerfile.*
.editorconfig
.dockerignore

# Exceptions: license + attribution files must be in build context so the
# runtime stage can COPY them into /licenses/ for redistribution compliance.
!LICENSE
!NOTICE
!THIRD_PARTY_NOTICES.md

# Credentials must never enter build context
.env
.env.*

# GitHub metadata
.github/
