{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SchwartzKamel/azure-openai-cli/scripts/provider-deps.schema.json",
  "title": "provider-deps mapping",
  "description": "Schema for scripts/provider-deps.json. Validated by scripts/provider-cve-report.sh before joining Trivy output against the map. Tooling only; AOT-irrelevant.",
  "type": "object",
  "required": ["version", "providers", "fallback_provider"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "providers": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "required": ["label", "patterns"],
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "patterns": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "owner": { "type": "string" },
            "notes": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "fallback_provider": { "type": "string", "minLength": 1 },
    "fallback_notes": { "type": "string" }
  }
}
